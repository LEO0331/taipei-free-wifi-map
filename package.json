{
  "name": "taipei-free-wifi-map",
  "version": "0.1.0",
  "description": "Mobile-first bilingual map and directory for Taipei Free public Wi-Fi hotspots.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "preview": "vite preview",
    "test": "node --import tsx --test tests/*.test.ts",
    "data:fetch": "node --import tsx scripts/fetchWifiHotspots.ts",
    "data:convert": "node --import tsx scripts/convertWifiHotspots.ts && node --import tsx scripts/buildWifiSummary.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LEO0331/taipei-free-wifi-map.git"
  },
  "keywords": [],
  "author": "LEO0331",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/LEO0331/taipei-free-wifi-map/issues"
  },
  "homepage": "https://LEO0331.github.io/taipei-free-wifi-map/",
  "dependencies": {
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
